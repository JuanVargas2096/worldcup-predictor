# Copia este archivo a .env y ajusta los valores.  (cp .env.example .env)
# .env NO se commitea (está en .gitignore).

# ---- Registry propio ----
REGISTRY=registry.mrvargas.net
TAG=latest

# ---- Despliegue (nginx-proxy + acme-companion en la red 'ranger') ----
# DNS público del frontend. El nginx-proxy genera el certificado para este host.
PUBLIC_HOST=worldcup-predictions.mrvargas.net
LETSENCRYPT_EMAIL=juanra.vargas@gmail.com

# ---- Base de datos (PostgreSQL contenerizado) ----
DB_NAME=worldcup
DB_USERNAME=worldcup
DB_PASSWORD=worldcup
DB_PORT=5432

# ---- Puertos expuestos ----
BACKEND_PORT=8080
FRONTEND_PORT=4200

# ---- App ----
# mock | external  (mock = siembra rápida al arranque; el cron trae datos reales cada 6h)
DATA_PROVIDER=mock

# API-Football (https://www.api-sports.io/). Sin key -> datos simulados (la app NO falla).
# Pon aquí tu key real SOLO en el archivo .env local/servidor (nunca en git).
FOOTBALL_API_KEY=NO_KEY
